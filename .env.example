# ==== Telegram (обычный бот в супергруппе-форуме) ====
# Токен бота от @BotFather
TG_BOT_TOKEN=123456:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ID супергруппы-форума (отрицательное, вида -100xxxxxxxxxx).
# Узнать: добавьте бота в группу и отправьте команду /id в любой теме.
TG_GROUP_ID=-1001234567890

# ==== MAX (ВАШ личный аккаунт = userbot) ====
# Телефон аккаунта MAX в международном формате
MAX_PHONE=+79991234567
# Каталог и имя файла сессии (создаются при первой авторизации через login.py)
MAX_WORK_DIR=max_session
MAX_SESSION=session.db

# ==== Поведение ====
# Пересылать сообщения из Telegram-веток обратно в MAX (от вашего имени)
FORWARD_TG_TO_MAX=true
# Подписывать сообщения именем отправителя
SHOW_SENDER_NAME=true
# Подгрузить N последних сообщений в ветку при первом её создании (0 = выкл).
# Делается один раз на чат. Напр. 20 — последние 20 сообщений истории.
BACKFILL_LIMIT=0

# ==== Прочее ====
DB_PATH=bridge.db
LOG_LEVEL=INFO
